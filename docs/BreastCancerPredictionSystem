# Paths
jpeg_root = "/kaggle/input/cbis-ddsm-breast-cancer-image-dataset/jpeg"
folders = os.listdir(jpeg_root)
print(f"Found {len(folders)} folders")

# Small Dataset for Demo
class SmallMammogramDataset(Dataset):
    def __init__(self, jpeg_root, folders, n_samples=20, transform=None):
        self.transform = transform
        self.data = []
        sampled_folders = random.sample(folders, min(n_samples, len(folders)))
        for folder in sampled_folders:
            folder_path = os.path.join(jpeg_root, folder)
            images = os.listdir(folder_path)
            if len(images) == 0:
                continue
            img_file = images[0]  # first image
            img_path = os.path.join(folder_path, img_file)
            label = random.randint(0,1)  # dummy label for demo
            self.data.append((img_path, label))
    
    def __len__(self):
        return len(self.data)
    
    def __getitem__(self, idx):
        img_path, label = self.data[idx]
        img = cv2.imread(img_path)
        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
        img = cv2.resize(img, (128,128))
        
        if self.transform:
            img = self.transform(img)
        else:
            img = torch.tensor(img/255., dtype=torch.float32).permute(2,0,1)
        
        return img, torch.tensor(label, dtype=torch.long)

# Normalization + Placeholder for Future Augmentation
transform = transforms.Compose([
    transforms.ToTensor(),
    transforms.Normalize(mean=[0.5,0.5,0.5], std=[0.5,0.5,0.5])
])

# Instantiate Dataset & DataLoader
dataset = SmallMammogramDataset(jpeg_root, folders, n_samples=20, transform=transform)
loader = DataLoader(dataset, batch_size=4, shuffle=True)
print(f"Dataset length: {len(dataset)}")

# Display Sample Images
plt.figure(figsize=(12,4))
for i in range(4):
    img, label = dataset[i]
    img_np = (img.permute(1,2,0).numpy()*0.5 + 0.5)  # unnormalize for display
    plt.subplot(1,4,i+1)
    plt.imshow(img_np)
    plt.title(f"Label: {label.item()}")
    plt.axis('off')
plt.tight_layout()
plt.show()

# Tiny CNN Definition
class TinyCNN(nn.Module):
    def __init__(self):
        super(TinyCNN, self).__init__()
        self.conv1 = nn.Conv2d(3, 8, 3, padding=1)
        self.conv2 = nn.Conv2d(8, 16, 3, padding=1)
        self.pool = nn.MaxPool2d(2,2)
        self.fc1 = nn.Linear(16*32*32, 32)
        self.dropout = nn.Dropout(0.3)
        self.fc2 = nn.Linear(32, 2)  # 2 classes
    
    def forward(self, x):
        x = self.pool(F.relu(self.conv1(x)))
        x = self.pool(F.relu(self.conv2(x)))
        x = torch.flatten(x,1)
        x = F.relu(self.fc1(x))
        x = self.dropout(x)
        x = self.fc2(x)
        return x

# Instantiate Model, Loss, Optimizer
device = "cuda" if torch.cuda.is_available() else "cpu"
model = TinyCNN().to(device)
criterion = nn.CrossEntropyLoss()
optimizer = torch.optim.Adam(model.parameters(), lr=0.001)
print(f"Using device: {device}")

# Train for 1 Epoch
model.train()
for i, (images, labels) in enumerate(loader):
    images, labels = images.to(device), labels.to(device)
    optimizer.zero_grad()
    outputs = model(images)
    loss = criterion(outputs, labels)
    loss.backward()
    optimizer.step()
    print(f"Batch {i+1}, Loss: {loss.item():.4f}")

# Evaluate on Demo Batch
model.eval()
all_labels = []
all_preds = []
with torch.no_grad():
    for images, labels in loader:
        images, labels = images.to(device), labels.to(device)
        outputs = model(images)
        _, preds = torch.max(outputs, 1)
        all_labels.extend(labels.cpu().tolist())
        all_preds.extend(preds.cpu().tolist())

# Accuracy
accuracy = sum([p==l for p,l in zip(all_preds, all_labels)]) / len(all_labels)
print(f"Demo Batch Accuracy: {accuracy*100:.2f}%")

# Confusion Matrix
cm = confusion_matrix(all_labels, all_preds)
plt.figure(figsize=(4,3))
sns.heatmap(cm, annot=True, fmt="d", cmap="Blues")
plt.xlabel("Predicted")
plt.ylabel("Actual")
plt.title("Confusion Matrix - Demo")
plt.show()

